      "Bash(powershell.exe -NoProfile -Command \"Write-Output $env:PATH\")",
      "Bash(echo $PATH)",
      "Bash(git init:*)",
      "Bash(git config:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  }

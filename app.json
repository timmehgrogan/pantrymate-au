{
  "expo": {
    "name": "PantryMate AU",
    "slug": "pantrymate-au",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pantrymateAU",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.pantrymate.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PantryMate uses your camera to scan barcodes on food products.",
        "NSPhotoLibraryUsageDescription": "PantryMate may access your photo library for product images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "au.pantrymate.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "PantryMate uses your camera to scan product barcodes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D6A4F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
